# Optional. If unset, the LLM disambiguation stage falls back to a deterministic
# stub (top-scored candidate, marked llm_degraded=true) — the service runs fully
# without this.
OPENAI_API_KEY=

# Model used for the disambiguation stage (only called when candidates are close).
OPENAI_MODEL=gpt-4o-mini

# SQLite file path.
DATABASE_URL=sqlite:///./role_inference.db
